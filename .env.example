# Oracle Cloud DB
ORACLE_USER=your_oracle_username
ORACLE_PASSWORD=your_oracle_password
ORACLE_CONNECTION_STRING=(description=(retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1522)(host=adb.ap-mumbai-1.oraclecloud.com))(connect_data=(service_name=your_service_name))(security=(ssl_server_dn_match=yes)))
ORACLE_WALLET_LOCATION=/path/to/wallet

# Auth
JWT_SECRET=your_very_long_random_secret_key_here
ADMIN_EMAIL=sharat@cognitivelamp.com
ADMIN_PASSWORD_HASH=generate_with_bcrypt

# Site
NEXT_PUBLIC_SITE_URL=https://cognitivelamp.com

# Email (optional, for contact form)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@cognitivelamp.com
SMTP_PASS=your_email_password